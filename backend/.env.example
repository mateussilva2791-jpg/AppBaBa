APP_NAME="Baba SaaS API"
ENVIRONMENT="development"
API_PREFIX="/api"
API_HOST="0.0.0.0"
API_PORT=8001
API_WORKERS=1
LOG_LEVEL="info"

# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
# Mínimo 32 caracteres — obrigatório, sem valor padrão
SECRET_KEY="SUBSTITUA-POR-UMA-CHAVE-SEGURA-COM-PELO-MENOS-32-CHARS"
ACCESS_TOKEN_EXPIRE_MINUTES=60

DATABASE_URL="postgresql+psycopg://postgres:postgres@localhost:5432/baba_saas"
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800

FRONTEND_URL="http://127.0.0.1:3001"
CORS_ALLOWED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001"
ALLOWED_HOSTS=""

# E-mail SMTP
# Para Gmail: smtp.gmail.com:587 com TLS e uma App Password (não a senha normal)
# Para Mailgun, SendGrid, etc: consulte a documentação do provedor
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="seu@gmail.com"
SMTP_PASSWORD="sua-app-password"
SMTP_FROM="App do Baba <noreply@appdobaba.com>"
SMTP_TLS=true
SMTP_ENABLED=false
